{
  "name": "coconut-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "NODE_OPTIONS='--disable-warning=DEP0169' expo start",
    "start:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo localhost) CI=false NODE_OPTIONS='--disable-warning=DEP0169' expo start",
    "android": "NODE_OPTIONS='--disable-warning=DEP0169' expo run:android",
    "ios": "NODE_OPTIONS='--disable-warning=DEP0169' expo run:ios",
    "ios:device": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo localhost) CI=false NODE_OPTIONS='--disable-warning=DEP0169' npx expo run:ios",
    "web": "NODE_OPTIONS='--disable-warning=DEP0169' expo start --web"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@clerk/expo": "^3.0.1",
    "@expo/vector-icons": "^15.1.1",
    "@stripe/stripe-terminal-react-native": "^0.0.1-beta.29",
    "expo": "~55.0.5",
    "expo-build-properties": "^55.0.9",
    "expo-clipboard": "^55.0.8",
    "expo-constants": "^55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-dev-client": "^55.0.11",
    "expo-document-picker": "^55.0.8",
    "expo-image-picker": "^55.0.11",
    "expo-linking": "^55.0.7",
    "expo-router": "^55.0.4",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^18.3.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
