# App variant: set to "development" for local dev build (Coconut Dev, bundle com.coconut.app.dev).
# Leave unset for TestFlight/production (Coconut, com.coconut.app). Lets you have both on the same device.
# APP_VARIANT=development

# Clerk (same as web app — must match NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...

# Backend API — your deployed coconut-web URL (e.g. Vercel).
# Bank linking (Plaid) uses this host; on Vercel set APP_URL and Plaid redirect URIs to the same origin.
EXPO_PUBLIC_API_URL=https://coconut-app.dev

# Tap to Pay on iPhone only: set true when Apple has added the proximity-reader entitlement to your
# provisioning profile. Omit or false for TestFlight/App Store builds if Xcode errors on that entitlement.
# ENABLE_TAP_TO_PAY_IOS=true

# Dev builds only (__DEV__): Stripe Terminal internet simulator + PAN 4242424242424242 — tests PI/collect/process only,
# not Tap to Pay on iPhone. Requires sk_test_. Restart Expo after changing.
# EXPO_PUBLIC_STRIPE_TERMINAL_SIMULATED=1

# Skip auth — show app without signing in (backend must have SKIP_AUTH=true)
# EXPO_PUBLIC_SKIP_AUTH=true

# First install only: if no demo preference in storage yet, start in demo mode (great for iOS Simulator QA).
# You can still turn Demo off on Shared. Omit for production/TestFlight.
# EXPO_PUBLIC_START_IN_DEMO=true

# Force sign-out on launch — only use briefly if stuck in sign-in loop (can cause isLoaded stuck; see docs/CLERK_ISLOADED_INVESTIGATION.md)
# EXPO_PUBLIC_FORCE_SIGN_OUT=false

# Native Google Sign-In — see docs/CLERK_GOOGLE_SETUP.md
# EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com
# EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
# EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.xxx
