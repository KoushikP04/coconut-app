# =============================================================================
# Coconut (Expo) — copy to .env and fill in. Never commit .env.
# =============================================================================

# --- Dev app variant (Coconut Dev, com.coconut.app.dev, scheme coconut-dev) ---
# Use either value; both enable the dev variant. Omit for production/TestFlight builds.
# npm scripts ios:dev / ios:dev:device set APP_VARIANT=dev for you.
# APP_VARIANT=dev
# APP_VARIANT=development

# --- Clerk (must match coconut web: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY) ---
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- Backend (coconut Next.js on Vercel or local) ---
# Mobile calls this for APIs; use deployed URL unless coconut web runs on your LAN.
EXPO_PUBLIC_API_URL=https://coconut-app.dev

# --- Real sign-in & bank data ---
# false = normal Clerk + API JWT (required for Plaid-linked account on device)
EXPO_PUBLIC_SKIP_AUTH=false

# Briefly true only if stuck in sign-in → loading (can worsen Clerk isLoaded; see docs)
EXPO_PUBLIC_FORCE_SIGN_OUT=false

# --- Native Google Sign-In + browser OAuth fallback (Clerk SSO) ---
# Web + iOS client IDs from Google Cloud; URL scheme = com.googleusercontent.apps.<id-prefix>
# See docs/CLERK_GOOGLE_SETUP.md and Clerk Dashboard → Native applications (iOS bundle ID).
EXPO_PUBLIC_CLERK_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_CLERK_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_CLERK_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.xxxxx

# --- Optional: Tap to Pay on iPhone (only if provisioning profile has the entitlement) ---
# ENABLE_TAP_TO_PAY_IOS=true
# EXPO_PUBLIC_ENABLE_TAP_TO_PAY_IOS=true

# --- Optional: Stripe Terminal dev simulator (__DEV__ only; Tap to Pay is separate) ---
# EXPO_PUBLIC_STRIPE_TERMINAL_SIMULATED=1

# --- Optional: first launch defaults to demo mode (simulator QA) ---
# EXPO_PUBLIC_START_IN_DEMO=true

# Note: Google browser SSO uses expo-auth-session (in package.json); no extra env key.
